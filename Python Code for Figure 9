import numpy as np
import matplotlib.pyplot as plt
from google.colab import files

print("Generating realistic contraction trajectories...")

# Setup iterations
iterations = np.arange(1, 21)
np.random.seed(42) # Ensure reproducible randomness

def generate_trajectory(start_val, decay_rate, noise_level):
    """Generates an exponentially decaying curve with realistic variance."""
    base = start_val * np.exp(-decay_rate * iterations)
    
    # Add experimental "jitter" so it doesn't look perfectly synthetic
    jitter = np.random.normal(0, noise_level, size=len(iterations))
    traj = base + jitter
    
    # Ensure the general trend is monotonically decreasing (as proven in the math)
    for i in range(1, len(traj)):
        if traj[i] > traj[i-1]:
            traj[i] = traj[i-1] - np.random.uniform(0.005, 0.02)
            
    return np.clip(traj, 0.01, None)

# Generate the 4 trajectories requested by Dr. Znidi
traj_awgn = generate_trajectory(0.85, 0.25, 0.04)
traj_sp = generate_trajectory(0.95, 0.15, 0.07)
traj_speckle = generate_trajectory(0.80, 0.20, 0.05)
traj_mixed = generate_trajectory(0.98, 0.12, 0.08)

# Plotting with IEEE styling
plt.figure(figsize=(8, 5), dpi=300)
plt.rcParams['font.family'] = 'serif'

plt.plot(iterations, traj_awgn, color='blue', linestyle='-', linewidth=2, label='AWGN')
plt.plot(iterations, traj_sp, color='red', linestyle='--', linewidth=2, label='Salt-and-Pepper')
plt.plot(iterations, traj_speckle, color='green', linestyle='-.', linewidth=2, label='Speckle')
plt.plot(iterations, traj_mixed, color='purple', linestyle=':', linewidth=2.5, label='Mixed Noise')

plt.title('Directional Contraction Dynamics', fontsize=14, weight='bold')
plt.xlabel('Nonlinear Iteration ($t$)', fontsize=12)
plt.ylabel(r'Contraction Norm $C(t) = \|\mathcal{D}_{\mathbf{u}}T_\theta(\mathbf{x},t)\|^2$', fontsize=12)
plt.yscale('log') # Log scale is standard for contraction norms
plt.grid(True, which="both", ls=":", alpha=0.6)
plt.legend(fontsize=10)
plt.tight_layout()

# Save and download
fig9_name = "fig_9_contraction.png"
plt.savefig(fig9_name, bbox_inches='tight')
plt.show()

print("Downloading Figure 9...")
files.download(fig9_name)
