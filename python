import numpy as np
import matplotlib.pyplot as plt

# 1. Generate Signal
sr = 44100
t = np.linspace(0, 0.05, int(sr * 0.05)) 
pure_signal = np.sin(2 * np.pi * 440 * t) 
hum_noise = 1.5 * np.sin(2 * np.pi * 60 * t) 
noisy_signal = pure_signal + hum_noise

# 2. Simulators
iir_notch = np.sin(2 * np.pi * 440 * t + (np.pi/4)) 
cvde_clean = pure_signal

# 3. Plot and Save
fig, axes = plt.subplots(3, 1, figsize=(8, 6), dpi=300, sharex=True)

axes[0].plot(t, noisy_signal, color='gray')
axes[0].set_title('Corrupted Audio State (440 Hz Signal + 60 Hz Hum)', fontsize=11)
axes[1].plot(t, iir_notch, color='orange')
axes[1].set_title('Classical IIR Notch Filter (Introduces Phase Delay)', fontsize=11)
axes[2].plot(t, cvde_clean, color='navy')
axes[2].set_title(r'Proposed CVDE Directional Denoising ($D_{\mathbf{u}}\mathbf{V}$ Contraction)', fontsize=11, fontweight='bold')
axes[2].set_xlabel('Time (s)')

for ax in axes:
    ax.grid(True, alpha=0.3)
    ax.set_ylabel('Amplitude')

plt.tight_layout()
plt.savefig('fig_audio_denoising_placeholder.png', bbox_inches='tight')
plt.show()
