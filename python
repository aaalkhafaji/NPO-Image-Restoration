import numpy as np
import matplotlib.pyplot as plt
import librosa
import librosa.display

# 1. Generate signal
sr = 22050
t = np.linspace(0, 2, sr * 2)
bass = np.sin(2 * np.pi * 60 * t) 
vocals = 0.5 * np.sin(2 * np.pi * 1000 * t) 
treble = 0.2 * np.random.randn(len(t)) 
audio = bass + vocals + treble

# 2. Spectrogram
D = librosa.amplitude_to_db(np.abs(librosa.stft(audio)), ref=np.max)

# 3. Plot and Save
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 6), dpi=300)

librosa.display.specshow(D, sr=sr, x_axis='time', y_axis='log', ax=ax1, cmap='magma')
ax1.set_title('Standard 1D Acoustic Spectrogram', fontsize=12)
ax1.set_xlabel('')

ax2.plot(t, bass, color='red', alpha=0.7, label=r'$b_L$ (Red / Low)')
ax2.plot(t, vocals, color='green', alpha=0.7, label=r'$b_M$ (Green / Mid)')
ax2.plot(t, treble, color='blue', alpha=0.5, label=r'$b_H$ (Blue / High)')
ax2.set_title('Spectral-Chromatic Decomposition $\mathbf{s} = (b_L, b_M, b_H)$', fontsize=12)
ax2.set_xlabel('Time (s)')
ax2.set_ylabel('Amplitude')
ax2.legend(loc='upper right')
ax2.set_xlim(0, 0.1)

plt.tight_layout()
plt.savefig('fig_audio_rgb_mapping_placeholder.png', bbox_inches='tight')
plt.show()




