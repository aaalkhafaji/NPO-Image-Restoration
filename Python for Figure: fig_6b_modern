import cv2
import numpy as np
import bm3d
from skimage import data, img_as_float
from matplotlib import pyplot as plt
from google.colab import files

# 1. Load a standard benchmark image (Cameraman)
original = img_as_float(data.camera())

# 2. Add Gaussian Noise (sigma = 25)
np.random.seed(42) # For reproducibility
sigma = 25 / 255.0
noisy = original + np.random.normal(0, sigma, original.shape)
noisy = np.clip(noisy, 0, 1)

# 3. Run BM3D (State-of-the-art classical filtering)
print("Running BM3D...")
bm3d_result = bm3d.bm3d(noisy, sigma_psd=sigma, stage_arg=bm3d.BM3DStages.ALL_STAGES)

# 4. Run INPO (Replace this placeholder with your actual INPO Python function)
print("Running INPO...")
def run_inpo(img):
    # INSERT YOUR INPO CODE HERE
    # For now, returning the noisy image as a placeholder
    return img 
inpo_result = run_inpo(noisy)

# 5. Save the images to standard 8-bit format
cv2.imwrite("original.png", (original * 255).astype(np.uint8))
cv2.imwrite("noisy_25.png", (noisy * 255).astype(np.uint8))
cv2.imwrite("bm3d_result.png", (bm3d_result * 255).astype(np.uint8))
cv2.imwrite("inpo_result.png", (inpo_result * 255).astype(np.uint8))

# 6. Download them to your computer
files.download("original.png")
files.download("noisy_25.png")
files.download("bm3d_result.png")
files.download("inpo_result.png")

print("Images generated and downloaded successfully!")


