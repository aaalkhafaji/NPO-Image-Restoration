import cv2
import matplotlib.pyplot as plt
from mpl_toolkits.axes_grid1.inset_locator import zoomed_inset_axes, mark_inset
import numpy as np
import os
from google.colab import files

# 1. Upload your images directly to Colab
print("Please upload your 6 image files (e.g., original.png, noisy_25.png, etc.)")
uploaded = files.upload()

# 2. Configuration: Map the titles to the exact filenames you just uploaded.
# UPDATE the string names on the right side to match your actual file names!
image_paths = {
    "Original": "original.png", 
    "Noisy ($\sigma=25$)": "noisy_25.png",
    "BM3D": "bm3d_result.png",
    "DnCNN": "dncnn_result.png",
    "FFDNet": "ffdnet_result.png",
    "Proposed INPO": "inpo_result.png"
}

# 3. Runtimes to display under each image
runtimes = {
    "Original": "",
    "Noisy ($\sigma=25$)": "",
    "BM3D": "Runtime: 148 ms",
    "DnCNN": "Runtime: 214 ms",
    "FFDNet": "Runtime: 173 ms",
    "Proposed INPO": "Runtime: 21 ms"
}

# 4. Zoom region coordinates (Adjust these to target your specific edge)
x1, x2 = 120, 180  
y1, y2 = 140, 200  
zoom_factor = 2.5  

# Create the figure layout
fig, axes = plt.subplots(3, 2, figsize=(8, 12))
axes = axes.flatten()

for idx, (title, filename) in enumerate(image_paths.items()):
    ax = axes[idx]
    
    # Check if the file was uploaded, otherwise use a blank placeholder
    if filename in os.listdir('.'):
        img = cv2.imread(filename, cv2.IMREAD_GRAYSCALE)
    else:
        print(f"Warning: '{filename}' not found. Using a black placeholder.")
        img = np.zeros((256, 256), dtype=np.uint8)
    
    # Display the main image
    ax.imshow(img, cmap='gray')
    ax.set_title(title, fontsize=14, fontweight='bold', pad=10)
    
    # Add runtime label
    if runtimes[title]:
        ax.set_xlabel(runtimes[title], fontsize=12, fontweight='bold', labelpad=5)
    
    ax.set_xticks([])
    ax.set_yticks([])
    
    # Create the zoomed inset region
    axins = zoomed_inset_axes(ax, zoom_factor, loc='lower right')
    axins.imshow(img, cmap='gray')
    
    # Set the zoom limits
    axins.set_xlim(x1, x2)
    axins.set_ylim(y2, y1) # y-axis inverted for images
    
    axins.set_xticks([])
    axins.set_yticks([])
    
    # Draw the red bounding box
    mark_inset(ax, axins, loc1=1, loc2=3, fc="none", ec="red", lw=1.5)

plt.tight_layout()

# Save the high-resolution figure to Colab's file system
plt.savefig("fig_6b_modern.png", dpi=300, bbox_inches='tight')
print("\nSuccess! Figure generated and saved.")

# Display it inline
plt.show()

